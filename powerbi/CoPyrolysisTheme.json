{
  "name": "CoPyrolysis Dark Theme",
  "dataColors": [
    "#F59E0B",
    "#10B981",
    "#6366F1",
    "#06B6D4",
    "#F43F5E",
    "#8B5CF6",
    "#F97316",
    "#84CC16",
    "#EC4899",
    "#14B8A6"
  ],
  "background": "#0F0F1A",
  "foreground": "#E2E8F0",
  "tableAccent": "#F59E0B",
  "good": "#10B981",
  "neutral": "#F59E0B",
  "bad": "#F43F5E",
  "maximum": "#10B981",
  "center": "#F59E0B",
  "minimum": "#F43F5E",
  "textClasses": {
    "callout": {
      "fontSize": 36,
      "fontFace": "Segoe UI",
      "color": "#E2E8F0"
    },
    "title": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#E2E8F0"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI",
      "color": "#94A3B8"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Segoe UI",
      "color": "#94A3B8"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#1A1A2E"
              }
            },
            "transparency": 5
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#2D2D44"
              }
            },
            "radius": 12
          }
        ],
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "fontSize": 13,
            "fontFamily": "Segoe UI Semibold"
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#0F0F1A"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#E2E8F0"
              }
            },
            "fontSize": 32
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#94A3B8"
              }
            },
            "fontSize": 12
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "outlineWeight": 0
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#94A3B8"
              }
            },
            "background": {
              "solid": {
                "color": "#1A1A2E"
              }
            }
          }
        ]
      }
    }
  }
}
